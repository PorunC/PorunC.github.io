<script>
  let dragTarget = null;

  function getDiagram(pre) {
    const code = pre.querySelector("code");
    return (code?.innerText ?? pre.innerText ?? pre.textContent ?? "").trimEnd();
  }

  function setupDragListeners() {
    if (window.__markdownMermaidDragInit) return;
    window.__markdownMermaidDragInit = true;

    window.addEventListener("mousemove", (event) => {
      if (!dragTarget) return;
      dragTarget.stage.scrollLeft = dragTarget.left + (dragTarget.x - event.clientX);
      dragTarget.stage.scrollTop = dragTarget.top + (dragTarget.y - event.clientY);
    });

    window.addEventListener("mouseup", () => {
      if (!dragTarget) return;
      dragTarget.stage.style.cursor = dragTarget.canDrag() ? "grab" : "default";
      dragTarget = null;
    });
  }

  function promoteMarkdownBlocks() {
    document
      .querySelectorAll('.article-body pre[data-language="mermaid"]:not([data-mermaid-promoted])')
      .forEach((pre, index) => {
        pre.setAttribute("data-mermaid-promoted", "true");

        const diagram = getDiagram(pre);
        if (!diagram.trim()) return;

        const id = `mermaid-md-${Date.now().toString(36)}-${index}`;
        const vertical = /^\s*(?:flowchart|graph)\s+(?:TD|TB)\b/m.test(diagram);
        const wrap = document.createElement("div");
        wrap.className = `mermaid-wrap${vertical ? " mermaid-vertical" : ""}`;
        wrap.id = `wrap-${id}`;
        wrap.setAttribute("data-markdown-mermaid", "true");
        wrap.innerHTML = `
          <div class="mermaid-stage" data-stage>
            <div class="mermaid-pane" data-pane>
              <pre id="${id}" class="mermaid"></pre>
            </div>
          </div>
          <div class="mermaid-actions">
            <button class="mermaid-btn" data-action="in" title="Zoom in">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/><line x1="11" y1="8" x2="11" y2="14"/></svg>
            </button>
            <button class="mermaid-btn" data-action="out" title="Zoom out">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            </button>
            <button class="mermaid-btn" data-action="reset" title="Reset">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
            </button>
            <span class="mermaid-sep"></span>
            <button class="mermaid-btn mermaid-btn-expand" data-action="expand" title="Fullscreen preview">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
            </button>
            <span class="mermaid-zoom-badge" data-zoom-level>100%</span>
          </div>
        `;

        wrap.querySelector("pre.mermaid").textContent = diagram;
        pre.replaceWith(wrap);
      });
  }

  function attachControls(wrap, svg, stage, badge) {
    const viewBoxWidth = svg.viewBox?.baseVal?.width || 0;
    const renderedWidth = svg.getBoundingClientRect().width || 0;
    const baseWidth = Math.max(viewBoxWidth, renderedWidth, 640);
    const vertical = wrap.classList.contains("mermaid-vertical");
    let zoom = 1;
    let expanded = false;
    let savedScroll = { left: 0, top: 0 };

    svg.removeAttribute("width");
    svg.removeAttribute("height");
    svg.style.maxWidth = "100%";
    svg.style.height = "auto";
    svg.style.display = "block";

    function canDrag() {
      return expanded || zoom > 1;
    }

    function apply() {
      if (!expanded && zoom === 1) {
        svg.style.width = "";
        svg.style.maxWidth = "100%";
      } else {
        svg.style.width = `${Math.round(baseWidth * zoom)}px`;
        svg.style.maxWidth = "none";
      }
      if (badge) badge.textContent = `${Math.round(zoom * 100)}%`;
      stage.style.cursor = canDrag() ? "grab" : "default";
    }

    function zoomAt(clientX, clientY, factor) {
      const rect = stage.getBoundingClientRect();
      const cx = clientX - rect.left;
      const cy = clientY - rect.top;
      const beforeX = stage.scrollLeft + cx;
      const beforeY = stage.scrollTop + cy;
      const nextZoom = Math.max(0.5, Math.min(zoom * factor, 5));
      const ratio = nextZoom / zoom;
      zoom = nextZoom;
      apply();
      stage.scrollLeft = beforeX * ratio - cx;
      stage.scrollTop = beforeY * ratio - cy;
    }

    function centerHorizontalScroll() {
      if (!vertical || expanded) return;
      requestAnimationFrame(() => {
        stage.scrollLeft = Math.max(0, (stage.scrollWidth - stage.clientWidth) / 2);
      });
    }

    function enterExpand() {
      expanded = true;
      savedScroll = { left: window.scrollX, top: window.scrollY };
      wrap.classList.add("expanded");
      document.documentElement.classList.add("mermaid-modal-open");
      requestAnimationFrame(() => {
        const stageWidth = stage.clientWidth || window.innerWidth;
        zoom = Math.max(1.6, Math.min(2.4, (stageWidth * 1.35) / baseWidth));
        apply();
        stage.scrollLeft = Math.max(0, (svg.clientWidth - stage.clientWidth) / 2);
        stage.scrollTop = Math.max(0, (svg.clientHeight - stage.clientHeight) / 2);
      });
    }

    function exitExpand() {
      expanded = false;
      wrap.classList.remove("expanded");
      document.documentElement.classList.remove("mermaid-modal-open");
      zoom = 1;
      stage.scrollLeft = 0;
      stage.scrollTop = 0;
      apply();
      centerHorizontalScroll();
      window.scrollTo(savedScroll.left, savedScroll.top);
    }

    wrap.querySelector("[data-action='in']")?.addEventListener("click", () => {
      const rect = stage.getBoundingClientRect();
      zoomAt(rect.left + rect.width / 2, rect.top + rect.height / 2, 1.35);
    });
    wrap.querySelector("[data-action='out']")?.addEventListener("click", () => {
      const rect = stage.getBoundingClientRect();
      zoomAt(rect.left + rect.width / 2, rect.top + rect.height / 2, 0.74);
    });
    wrap.querySelector("[data-action='reset']")?.addEventListener("click", () => {
      zoom = expanded
        ? Math.max(1.6, Math.min(2.4, ((stage.clientWidth || window.innerWidth) * 1.35) / baseWidth))
        : 1;
      apply();
      stage.scrollLeft = expanded ? Math.max(0, (svg.clientWidth - stage.clientWidth) / 2) : 0;
      stage.scrollTop = expanded ? Math.max(0, (svg.clientHeight - stage.clientHeight) / 2) : 0;
      centerHorizontalScroll();
    });
    wrap.querySelector("[data-action='expand']")?.addEventListener("click", () => {
      if (expanded) exitExpand();
      else enterExpand();
    });

    stage.addEventListener("click", (event) => {
      if (expanded && event.target === stage) exitExpand();
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && expanded) exitExpand();
    });
    stage.addEventListener(
      "wheel",
      (event) => {
        if (!event.ctrlKey && !event.metaKey) return;
        event.preventDefault();
        zoomAt(event.clientX, event.clientY, event.deltaY < 0 ? 1.1 : 0.9);
      },
      { passive: false },
    );
    stage.addEventListener("mousedown", (event) => {
      if (event.button !== 0 || !canDrag()) return;
      event.preventDefault();
      dragTarget = {
        stage,
        x: event.clientX,
        y: event.clientY,
        left: stage.scrollLeft,
        top: stage.scrollTop,
        canDrag,
      };
      stage.style.cursor = "grabbing";
    });

    apply();
    centerHorizontalScroll();
  }

  async function enhanceMarkdownMermaid() {
    promoteMarkdownBlocks();

    const diagrams = document.querySelectorAll(
      '.article-body .mermaid-wrap[data-markdown-mermaid] pre.mermaid:not([data-rendered])',
    );
    if (!diagrams.length) return;

    setupDragListeners();
    const { default: mermaid } = await import("mermaid");
    if (!window.__mermaidInit) {
      window.__mermaidInit = true;
      mermaid.initialize({ startOnLoad: false, theme: "default" });
    }

    for (const diagram of diagrams) {
      try {
        diagram.setAttribute("data-rendered", "1");
        await mermaid.run({ nodes: [diagram] });

        const wrap = diagram.closest(".mermaid-wrap");
        const stage = wrap?.querySelector("[data-stage]");
        const pane = wrap?.querySelector("[data-pane]");
        const badge = wrap?.querySelector("[data-zoom-level]");
        const svg = pane?.querySelector("svg");
        if (wrap && stage && svg) attachControls(wrap, svg, stage, badge);
      } catch (error) {
        console.warn("[Mermaid] Markdown render failed:", error);
        diagram.removeAttribute("data-rendered");
      }
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", enhanceMarkdownMermaid, { once: true });
  } else {
    enhanceMarkdownMermaid();
  }
  document.addEventListener("astro:page-load", enhanceMarkdownMermaid);
</script>

<style is:global>
