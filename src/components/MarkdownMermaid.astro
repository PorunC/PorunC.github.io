    position: relative;
    width: 100%;
    clear: both;
    margin: 2.5rem 0;
    overflow-x: auto;
    overflow-y: hidden;
  }

  .article-body .mermaid-stage {
    width: 100%;
    overflow: auto;
    cursor: default;
    scrollbar-width: thin;
  }

  .article-body .mermaid-pane {
    width: max-content;
    min-width: 100%;
  }

  .article-body .mermaid-pane svg {
    display: block;
    margin: 0 auto;
  }

  .article-body .mermaid-pane pre {
    margin: 0;
    border: none;
    background: transparent;
    padding: 0;
    line-height: 0;
  }

  .article-body .mermaid-actions {
    position: absolute;
    top: 6px;
    right: 6px;
    z-index: 10;
    display: flex;
    gap: 4px;
    align-items: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
  }

  .article-body .mermaid-wrap:hover .mermaid-actions,
  .article-body .mermaid-actions:has(:focus-visible) {
    opacity: 1;
    pointer-events: auto;
  }

  .article-body .mermaid-btn {
    display: flex;
    width: 28px;
    height: 28px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.9);
    color: #444;
    cursor: pointer;
    pointer-events: auto;
    transition: all 0.12s;
    backdrop-filter: blur(4px);
  }

  .article-body .mermaid-btn:hover {
    background: #fff;
    color: #111;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.1);
  }

  .article-body .mermaid-btn:active {
    transform: scale(0.93);
  }

  .article-body .mermaid-zoom-badge {
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.8);
    color: #888;
    padding: 2px 6px;
    font-family: ui-monospace, monospace;
    font-size: 11px;
  }

  .article-body .mermaid-sep {
    width: 1px;
    height: 16px;
    flex-shrink: 0;
    background: rgba(0, 0, 0, 0.1);
  }

  .article-body .mermaid-wrap.expanded {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    margin: 0;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.45);
    padding: 24px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .article-body .mermaid-wrap.expanded .mermaid-stage {
    width: min(96vw, 1800px);
    height: min(88vh, 1100px);
    overflow: auto;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.96);
    padding: 28px;
    box-shadow: 0 18px 70px rgba(0, 0, 0, 0.28);
  }

  .article-body .mermaid-wrap.expanded .mermaid-pane {
    min-width: max-content;
    padding: 16px;
  }

  .article-body .mermaid-wrap.expanded .mermaid-pane svg {
    max-width: none !important;
    max-height: none !important;
    height: auto !important;
    margin: 0;
  }

  .article-body .mermaid-wrap.expanded .mermaid-actions {
    top: 16px;
    right: 16px;
    opacity: 1;
    pointer-events: auto;
  }

  .article-body .mermaid-wrap.expanded .mermaid-btn-expand svg {
    transform: rotate(45deg);
  }

  html.mermaid-modal-open {
    overflow: hidden;
  }
</style>
