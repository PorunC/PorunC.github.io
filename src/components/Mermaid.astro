---
import { randomUUID } from 'node:crypto';

const id = `mermaid-${randomUUID().slice(0, 8)}`;
const { diagram, size, compact = false } = Astro.props;
const sizeClass = ['sm', 'md', 'lg', 'wide'].includes(size) ? `mermaid-${size}` : '';
const compactClass = compact ? 'mermaid-compact' : '';
const verticalClass = /^\s*(?:flowchart|graph)\s+(?:TD|TB)\b/m.test(diagram)
  ? 'mermaid-vertical'
  : '';
---

<div class={`mermaid-wrap ${sizeClass} ${compactClass} ${verticalClass}`} id={`wrap-${id}`}>
  <div class="mermaid-stage" data-stage>
    <div class="mermaid-pane" data-pane>
      <pre id={id} class="mermaid">{diagram}</pre>
    </div>
  </div>
  <div class="mermaid-actions">
    <button class="mermaid-btn" data-action="in" title="放大 (Ctrl+滚轮)">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/><line x1="11" y1="8" x2="11" y2="14"/></svg>
    </button>
    <button class="mermaid-btn" data-action="out" title="缩小 (Ctrl+滚轮)">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
    </button>
    <button class="mermaid-btn" data-action="reset" title="重置">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
    </button>
    <span class="mermaid-sep"></span>
    <button class="mermaid-btn mermaid-btn-expand" data-action="expand" title="全屏预览">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
    </button>
    <span class="mermaid-zoom-badge" data-zoom-level>100%</span>
  </div>
</div>

<script>
  import mermaid from "mermaid";

  if (!window.__mermaidInit) {
    window.__mermaidInit = true;
    mermaid.initialize({ startOnLoad: false, theme: "default" });
  }

  let _dragTarget = null;

  function _onMove(e) {
    if (!_dragTarget) return;
    const d = _dragTarget;
    d.stage.scrollLeft = d.left + (d.x - e.clientX);
    d.stage.scrollTop = d.top + (d.y - e.clientY);
  }
  function _onUp() {
    if (!_dragTarget) return;
    _dragTarget.stage.style.cursor = _dragTarget.canDrag() ? "grab" : "default";
    _dragTarget = null;
  }
  if (!window.__mermaidDragInit) {
    window.__mermaidDragInit = true;
    window.addEventListener("mousemove", _onMove);
    window.addEventListener("mouseup", _onUp);
  }

  (async () => {
    const els = document.querySelectorAll(".mermaid:not([data-rendered])");
    for (const el of els) {
      try {
        el.setAttribute("data-rendered", "1");
        await mermaid.run({ nodes: [el] });

        const wrap = el.closest(".mermaid-wrap");
        if (!wrap) continue;

        const stage = wrap.querySelector("[data-stage]");
        const pane = wrap.querySelector("[data-pane]");
        const badge = wrap.querySelector("[data-zoom-level]");
        const svg = pane.querySelector("svg");
        if (!svg || !stage || !pane) continue;

        const viewBoxWidth = svg.viewBox?.baseVal?.width || 0;
        const renderedWidth = svg.getBoundingClientRect().width || 0;
        const baseWidth = Math.max(viewBoxWidth, renderedWidth, 640);
        const compact = wrap.classList.contains("mermaid-compact");
        const vertical = wrap.classList.contains("mermaid-vertical");
        const baseScale = compact ? 0.72 : 1;
        svg.removeAttribute("width");
        svg.removeAttribute("height");
        svg.style.maxWidth = "100%";
        svg.style.height = "auto";
        svg.style.display = "block";

        let zoom = 1;
        let expanded = false;
        let savedScroll = { left: 0, top: 0 };

        function apply() {
          if (!expanded && zoom === 1) {
            svg.style.width = compact ? `${Math.round(baseWidth * baseScale)}px` : "";
            svg.style.maxWidth = "100%";
          } else {
            svg.style.width = `${Math.round(baseWidth * zoom)}px`;
            svg.style.maxWidth = "none";
          }
          if (badge) badge.textContent = `${Math.round(zoom * 100)}%`;
          stage.style.cursor = canDrag() ? "grab" : "default";
        }

        function zoomAt(clientX, clientY, factor) {
          const rect = stage.getBoundingClientRect();
          const cx = clientX - rect.left;
          const cy = clientY - rect.top;
          const beforeX = stage.scrollLeft + cx;
          const beforeY = stage.scrollTop + cy;
          const nextZoom = Math.max(0.5, Math.min(zoom * factor, 5));
          const ratio = nextZoom / zoom;
          zoom = nextZoom;
          apply();
          stage.scrollLeft = beforeX * ratio - cx;
          stage.scrollTop = beforeY * ratio - cy;
        }

        function canDrag() {
          return expanded || zoom > 1;
        }

        function centerHorizontalScroll() {
          if (!vertical || expanded) return;
          requestAnimationFrame(() => {
            stage.scrollLeft = Math.max(0, (stage.scrollWidth - stage.clientWidth) / 2);
          });
        }

        function enterExpand() {
          expanded = true;
          savedScroll = {
            left: window.scrollX,
            top: window.scrollY,
          };
          wrap.classList.add("expanded");
          document.documentElement.classList.add("mermaid-modal-open");
          requestAnimationFrame(() => {
            const stageWidth = stage.clientWidth || window.innerWidth;
            zoom = Math.max(1.6, Math.min(2.4, (stageWidth * 1.35) / baseWidth));
            apply();
            stage.scrollLeft = Math.max(0, (svg.clientWidth - stage.clientWidth) / 2);
            stage.scrollTop = Math.max(0, (svg.clientHeight - stage.clientHeight) / 2);
          });
        }

        function exitExpand() {
          expanded = false;
          wrap.classList.remove("expanded");
          document.documentElement.classList.remove("mermaid-modal-open");
          zoom = 1;
          stage.scrollLeft = 0;
          stage.scrollTop = 0;
          apply();
          centerHorizontalScroll();
          window.scrollTo(savedScroll.left, savedScroll.top);
        }

        // Toolbar
        wrap.querySelector("[data-action='in']")?.addEventListener("click", () => {
          const r = stage.getBoundingClientRect();
          zoomAt(r.left + r.width / 2, r.top + r.height / 2, 1.35);
        });
        wrap.querySelector("[data-action='out']")?.addEventListener("click", () => {
          const r = stage.getBoundingClientRect();
          zoomAt(r.left + r.width / 2, r.top + r.height / 2, 0.74);
        });
        wrap.querySelector("[data-action='reset']")?.addEventListener("click", () => {
          zoom = expanded ? Math.max(1.6, Math.min(2.4, ((stage.clientWidth || window.innerWidth) * 1.35) / baseWidth)) : 1;
          apply();
          stage.scrollLeft = expanded ? Math.max(0, (svg.clientWidth - stage.clientWidth) / 2) : 0;
          stage.scrollTop = expanded ? Math.max(0, (svg.clientHeight - stage.clientHeight) / 2) : 0;
          centerHorizontalScroll();
        });
        wrap.querySelector("[data-action='expand']")?.addEventListener("click", () => {
          if (expanded) exitExpand(); else enterExpand();
        });

        // Click outside SVG to close overlay
        stage.addEventListener("click", (e) => {
          if (expanded && e.target === stage) {
            exitExpand();
          }
        });

        // Escape to close overlay
        const onKey = (e) => { if (e.key === "Escape" && expanded) exitExpand(); };
        document.addEventListener("keydown", onKey);

        // Ctrl/Meta + wheel zoom
        stage.addEventListener("wheel", (e) => {
          if (!e.ctrlKey && !e.metaKey) return;
          e.preventDefault();
          zoomAt(e.clientX, e.clientY, e.deltaY < 0 ? 1.1 : 0.9);
        }, { passive: false });

        // Drag when zoomed in
        stage.addEventListener("mousedown", (e) => {
          if (e.button !== 0 || !canDrag()) return;
          e.preventDefault();
          _dragTarget = {
            stage,
            x: e.clientX,
            y: e.clientY,
            left: stage.scrollLeft,
            top: stage.scrollTop,
            canDrag,
          };
          stage.style.cursor = "grabbing";
        });

        apply();
        centerHorizontalScroll();
      } catch (e) {
        console.warn("[Mermaid] render failed:", e);
        el.removeAttribute("data-rendered");
      }
    }
  })();
</script>

<style>
  .mermaid-wrap {
    position: relative;
    margin: 2.5rem 0;
    overflow-x: auto;
    overflow-y: hidden;
    clear: both;
    width: 100%;
  }
  .mermaid-stage {
    overflow: auto;
    cursor: default;
    width: 100%;
    scrollbar-width: thin;
  }
  .mermaid-pane {
    width: max-content;
    min-width: 100%;
  }
  .mermaid-pane svg {
    display: block;
    margin: 0 auto;
  }
  .mermaid-sm .mermaid-pane svg {
    max-width: min(100%, 640px) !important;
  }
  .mermaid-md .mermaid-pane svg {
    max-width: min(100%, 820px) !important;
  }
  .mermaid-lg .mermaid-pane svg {
    max-width: min(100%, 980px) !important;
  }
  .mermaid-wide .mermaid-pane svg {
    max-width: min(100%, 1120px) !important;
  }
  .mermaid-pane pre {
    margin: 0;
    padding: 0;
    background: transparent;
    border: none;
    line-height: 0;
  }

  /* Floating actions on hover */
  .mermaid-actions {
    position: absolute;
    top: 6px;
    right: 6px;
    display: flex;
    align-items: center;
    gap: 4px;
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 10;
    pointer-events: none;
  }
  .mermaid-wrap:hover .mermaid-actions,
  .mermaid-actions:has(:focus-visible) {
    opacity: 1;
    pointer-events: auto;
  }
  .mermaid-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    border: 1px solid rgba(0,0,0,0.12);
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(4px);
    cursor: pointer;
    color: #444;
    transition: all 0.12s;
    pointer-events: auto;
  }
  .mermaid-btn:hover { background: #fff; color: #111; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }
  .mermaid-btn:active { transform: scale(0.93); }
  .mermaid-zoom-badge {
    font-size: 11px;
    color: #888;
    font-family: ui-monospace, monospace;
    background: rgba(255,255,255,0.8);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid rgba(0,0,0,0.08);
  }
  .mermaid-sep {
    width: 1px;
    height: 16px;
    background: rgba(0,0,0,0.1);
    flex-shrink: 0;
  }

  /* ===== Overlay / Expand mode ===== */
  .mermaid-wrap.expanded {
    position: fixed;
    inset: 0;
    z-index: 9999;
    margin: 0;
    overflow: hidden;
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    display: grid;
    place-items: center;
    padding: 24px;
  }
  .mermaid-wrap.expanded .mermaid-stage {
    overflow: auto;
    width: min(96vw, 1800px);
    height: min(88vh, 1100px);
    background: rgba(255,255,255,0.96);
    border-radius: 8px;
    box-shadow: 0 18px 70px rgba(0,0,0,0.28);
    padding: 28px;
  }
  .mermaid-wrap.expanded .mermaid-pane {
    min-width: max-content;
    padding: 16px;
  }
  .mermaid-wrap.expanded .mermaid-pane svg {
    margin: 0;
    max-width: none !important;
    max-height: none !important;
    height: auto !important;
  }
  .mermaid-wrap.expanded .mermaid-actions {
    top: 16px;
    right: 16px;
    opacity: 1;
    pointer-events: auto;
  }
  .mermaid-wrap.expanded .mermaid-btn-expand svg {
    transform: rotate(45deg);
  }
  :global(html.mermaid-modal-open) {
    overflow: hidden;
  }
</style>
