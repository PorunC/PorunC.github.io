---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts, getCategoryUrl, getTermCounts } from '../../lib/posts';

const posts = await getAllPosts();
const categories = getTermCounts(posts, 'categories');
---

<BaseLayout title="分类" current="categories">
  <section class="simple-page">
    <h1 class="page-title">分类</h1>
    <ul class="term-list">
      {categories.map(([category, count]) => (
        <li><a href={getCategoryUrl(category)}>{category}</a><span>{count}</span></li>
      ))}
    </ul>
  </section>
</BaseLayout>
